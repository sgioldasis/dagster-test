# Ingestion Code Location - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# CSV Data Configuration (Required)
# =============================================================================

# Absolute path to the CSV data directory (REQUIRED)
# Example: /home/user/projects/dagster-poc/data
CSV_DATA_PATH=/path/to/your/dagster-poc/data

# =============================================================================
# PostgreSQL Configuration (Required for local ingestion)
# =============================================================================

LOCAL_POSTGRES_HOST=localhost
LOCAL_POSTGRES_PORT=5432
LOCAL_POSTGRES_USER=postgres
LOCAL_POSTGRES_PASSWORD=
LOCAL_POSTGRES_DATABASE=postgres

# Alternative: Supabase PostgreSQL (if using supabase target)
SUPABASE_HOST=
SUPABASE_PORT=5432
SUPABASE_USER=
SUPABASE_PASSWORD=
SUPABASE_DATABASE=postgres

# Ingestion target: "local" or "supabase"
INGESTION_TARGET=local

# =============================================================================
# Databricks Configuration (Optional - for Databricks features)
# =============================================================================

DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_HTTP_PATH=
DATABRICKS_CATALOG=test
DATABRICKS_SCHEMA=main

# Databricks Notebook Job ID (optional - for triggering external jobs)
DATABRICKS_NOTEBOOK_JOB_ID=

# Use serverless compute (default: true)
DATABRICKS_USE_SERVERLESS=true

# =============================================================================
# DLT Configuration (Optional - for DLT ingestion)
# =============================================================================

# PostgreSQL credentials for DLT
DESTINATION__POSTGRES__CREDENTIALS__PASSWORD=

# =============================================================================
# Output Configuration
# =============================================================================

OUTPUT_DIR=./output

# =============================================================================
# Environment
# =============================================================================

ENVIRONMENT=development
