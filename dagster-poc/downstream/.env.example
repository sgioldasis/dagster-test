# Downstream Code Location - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# dbt Cloud Configuration (Required for accessing dbt Cloud API)
# =============================================================================

# dbt Cloud API token (required for querying dbt Cloud)
DBT_CLOUD_TOKEN=

# Your dbt Cloud account ID (required)
DBT_CLOUD_ACCOUNT_ID=

# dbt Cloud access URL (default: https://cloud.getdbt.com)
DBT_CLOUD_ACCESS_URL=https://cloud.getdbt.com

# dbt Cloud project ID (required)
DBT_CLOUD_PROJECT_ID=

# dbt Cloud environment ID (required)
DBT_CLOUD_ENVIRONMENT_ID=

# =============================================================================
# Output Configuration
# =============================================================================

# Directory for output files (default: ./output)
OUTPUT_DIR=./output

# =============================================================================
# Environment
# =============================================================================

ENVIRONMENT=development
