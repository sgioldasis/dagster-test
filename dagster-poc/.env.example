# DBT Cloud Configuration
DBT_CLOUD_TOKEN=
DBT_CLOUD_ACCOUNT_ID=
DBT_CLOUD_ACCESS_URL=https://cloud.getdbt.com
DBT_CLOUD_PROJECT_ID=
DBT_CLOUD_ENVIRONMENT_ID=
DBT_CLOUD_JOB_ID=

# DBT Cloud Run Configuration
DBT_CLOUD_RUN_TIMEOUT_SECONDS=600
DBT_CLOUD_POLLING_INTERVAL=30
DBT_CLOUD_MAX_CONCURRENT_RUNS=3
DBT_CLOUD_RETRY_FAILED=false

# Databricks Configuration
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_CATALOG=test
DATABRICKS_SCHEMA=main
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_HTTP_PATH=
DATABRICKS_NOTEBOOK_PATH=
DATABRICKS_USE_SERVERLESS=true

# Databricks Notebook Job Configuration
DATABRICKS_NOTEBOOK_JOB_ID=

# Ingestion Target (local or supabase)
INGESTION_TARGET=local

# Local PostgreSQL Configuration (uses peer auth - no password)
LOCAL_POSTGRES_HOST=localhost
LOCAL_POSTGRES_PORT=5432
LOCAL_POSTGRES_USER=
LOCAL_POSTGRES_PASSWORD=
LOCAL_POSTGRES_DATABASE=postgres

# PostgreSQL Connection String
POSTGRES_CONNECTION_STRING=

# DLT Environment Variables for PostgreSQL credentials
DESTINATION__POSTGRES__CREDENTIALS__PASSWORD=

# Supabase PostgreSQL Configuration (still available if needed)
SUPABASE_HOST=
SUPABASE_PORT=5432
SUPABASE_USER=
SUPABASE_PASSWORD=
SUPABASE_DATABASE=postgres

# CSV Data Configuration
CSV_DATA_PATH=/path/to/your/dagster-poc/data

# Output directory for downstream assets
OUTPUT_DIR=./output

# Environment selection (development, staging, production)
ENVIRONMENT=development
