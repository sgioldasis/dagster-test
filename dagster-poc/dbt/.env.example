# dbt Code Location - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# dbt Cloud Configuration (Required)
# =============================================================================

# dbt Cloud API token (required)
DBT_CLOUD_TOKEN=

# Your dbt Cloud account ID (required)
DBT_CLOUD_ACCOUNT_ID=

# dbt Cloud access URL (default: https://cloud.getdbt.com)
DBT_CLOUD_ACCESS_URL=https://cloud.getdbt.com

# dbt Cloud project ID (required)
DBT_CLOUD_PROJECT_ID=

# dbt Cloud environment ID (required)
DBT_CLOUD_ENVIRONMENT_ID=

# Specific job ID to trigger (optional)
DBT_CLOUD_JOB_ID=

# =============================================================================
# dbt Cloud Run Configuration (Optional)
# =============================================================================

# Timeout for dbt Cloud runs in seconds (default: 600)
DBT_CLOUD_RUN_TIMEOUT_SECONDS=600

# Polling interval in seconds (default: 30)
DBT_CLOUD_POLLING_INTERVAL=30

# Max concurrent runs (default: 3)
DBT_CLOUD_MAX_CONCURRENT_RUNS=3

# Retry failed runs (default: false)
DBT_CLOUD_RETRY_FAILED=false

# =============================================================================
# Environment
# =============================================================================

ENVIRONMENT=development
